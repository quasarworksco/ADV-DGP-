<script>
  /* ═══════════════════════════════════════════
     NAVIGATION
  ═══════════════════════════════════════════ */
  function switchPage(page, btn) {
    document.querySelectorAll('.nav-tab').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.getElementById('page-' + page).classList.add('active');
  }

  function switchSubTab(tab, btn) {
    document.querySelectorAll('.subtab-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('subtab-nuevo').style.display     = tab === 'nuevo' ? 'grid' : 'none';
    document.getElementById('subtab-historial').style.display = tab === 'historial' ? 'block' : 'none';
    if (tab === 'historial') renderHistorial();
  }


  /* ═══════════════════════════════════════════
     PANEL DE VENTAS
  ═══════════════════════════════════════════ */
  const SCRIPT_VENTAS = "https://script.google.com/macros/s/AKfycbzIFxM6T6yGOl2GBQnwqYZyrg5HtEexNlDj8LrMGgZqglzWuY75AcQNzwBcCBlACf_haQ/exec";
  let DATOS = [];
  const INITIALS = { 'Kevin Bermudez':'K', 'Angel Rosales':'A', 'Jose Acosta':'J', 'Paul Espina':'P' };

  async function cargar() {
    const h = new Date();
    const numSemana = Math.ceil(h.getDate() / 7);
    const mes = h.toLocaleString('es-ES', { month: 'long' }).toUpperCase();
    document.getElementById('txtSemana').innerText = `${mes} — SEMANA ${numSemana}`;
    try {
      const res = await fetch(SCRIPT_VENTAS + "?v=" + Math.random());
      DATOS = await res.json();
      render();
    } catch(e) {
      document.getElementById('txtSemana').innerText = "ERROR AL CARGAR";
    }
  }

  function render() {
    let sumas = { "Kevin Bermudez":0, "Angel Rosales":0, "Jose Acosta":0, "Paul Espina":0 };
    let rachas = {};
    let global = 0;
    const hoy = new Date();
    const hoyStr = hoy.toLocaleDateString();
    const semanaActual = Math.ceil(hoy.getDate() / 7);
    const mesActual = hoy.getMonth();
    const añoActual = hoy.getFullYear();

    DATOS.forEach((f, i) => {
      const fechaVenta = new Date(f[0]);
      const m = parseFloat(f[4]) || 0;
      const emp = f[1];
      const semanaVenta = Math.ceil(fechaVenta.getDate() / 7);

      if (semanaVenta === semanaActual && fechaVenta.getMonth() === mesActual && fechaVenta.getFullYear() === añoActual) {
        if (sumas.hasOwnProperty(emp)) sumas[emp] += m;
        global += m;
        if (fechaVenta.toLocaleDateString() === hoyStr) rachas[emp] = true;
      }

      if (i === DATOS.length - 1) {
        const tickEl = document.getElementById('ticker');
        const tickText = document.getElementById('tickerText');
        const msg = `🔥 ÚLTIMA VENTA — ${emp.split(' ')[0]} cerró $${m.toFixed(2)} con ${f[2]}`;
        tickText.innerText = msg + '   ·   ' + msg;
        tickEl.style.display = 'block';
      }
    });

    const p = Math.min((global / 1000) * 100, 100);
    document.getElementById('barFill').style.width = p + '%';
    document.getElementById('valActual').innerText = global.toFixed(2);
    document.getElementById('valPorcentaje').innerText = p.toFixed(1) + '%';
    const faltante = 1000 - global;
    document.getElementById('txtFaltante').innerText = faltante > 0
      ? `Faltan $${faltante.toFixed(2)} para el bono`
      : '¡BONO ALCANZADO! 🏆';

    const max = Math.max(...Object.values(sumas));
    for (let e in sumas) {
      const id = e.split(' ')[0];
      const card = document.getElementById(`card-${id}`);
      if (!card) continue;
      document.getElementById(`total-${id}`).innerText = `$${sumas[e].toFixed(2)}`;
      card.classList.remove('leader');
      card.querySelectorAll('.rank-medal, .rank-streak').forEach(el => el.remove());
      if (rachas[e]) card.insertAdjacentHTML('beforeend','<span class="rank-streak">🔥</span>');
      if (sumas[e] === max && max > 0) {
        card.classList.add('leader');
        card.insertAdjacentHTML('beforeend','<span class="rank-medal">🏆</span>');
      }
    }

    renderLista(DATOS);
  }

  function renderLista(data) {
    const el = document.getElementById('listaVentas');
    if (!data.length) {
      el.innerHTML = '<div class="empty-state"><div>📭</div>Sin movimientos aún</div>';
      return;
    }
    let html = '';
    data.slice().reverse().slice(0,12).forEach((f, i) => {
      const emp     = f[1] || '';
      const ini     = INITIALS[emp] || emp[0] || '?';
      const nombre  = emp.split(' ')[0];
      const cliente = f[2] || '';
      const servicio= f[3] || '';
      const monto   = parseFloat(f[4]) || 0;
      const fecha   = new Date(f[0]).toLocaleDateString('es-ES',{day:'2-digit',month:'short'});
      html += `
        <div class="venta-row" style="animation-delay:${i*0.05}s">
          <div class="venta-avatar">${ini}</div>
          <div class="venta-info">
            <div class="venta-name">${nombre} <span style="font-weight:300;color:var(--text-soft)">· ${cliente}</span></div>
            <div class="venta-client">${servicio}</div>
          </div>
          <span class="venta-service">${servicio}</span>
          <span class="venta-date">${fecha}</span>
          <span class="venta-amount">$${monto.toFixed(2)}</span>
        </div>`;
    });
    el.innerHTML = html;
  }

  function filtrar(nom, btn) {
    document.querySelectorAll('.btn-filter').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const f = nom === 'Todos' ? DATOS : DATOS.filter(d => d[1] && d[1].includes(nom));
    renderLista(f);
  }

  async function registrar() {
    const e = document.getElementById('fEmp').value;
    const c = document.getElementById('fCli').value.trim();
    const s = document.getElementById('fSer').value;
    const m = document.getElementById('fMon').value;
    if (!c || !m) return alert('⚠️ Por favor ingresa el nombre del cliente y el monto.');

    const btn = document.querySelector('.btn-reg');
    btn.innerHTML = '<span>PROCESANDO...</span>';
    btn.disabled = true;

    try {
      await fetch(SCRIPT_VENTAS, {
        method: 'POST', mode: 'no-cors',
        body: JSON.stringify({ empleado:e, cliente:c, servicio:s, monto:m })
      });
      document.getElementById('pResumen').innerText =
        `${e.split(' ')[0]} cerró $${parseFloat(m).toFixed(2)} con ${c} — ${s}`;
      document.getElementById('lnkWA').href =
        `https://wa.me/584121002090?text=*NUEVA VENTA DGP GROUP*%0A👤 ${e}%0A🤝 ${c}%0A💼 ${s}%0A💰 $${m}`;
      document.getElementById('modalExito').classList.add('show');
    } catch(err) {
      alert('Error al registrar. Verifica tu conexión.');
      btn.innerHTML = '<span style="display:flex;align-items:center;gap:10px"><i class="fa-solid fa-rocket"></i> GUARDAR VENTA</span><span class="arr"><i class="fa-solid fa-arrow-right"></i></span>';
      btn.disabled = false;
    }
  }

  function cerrarModalVenta() {
    document.getElementById('modalExito').classList.remove('show');
    document.getElementById('fCli').value = '';
    document.getElementById('fMon').value = '';
    const btn = document.querySelector('.btn-reg');
    btn.innerHTML = '<span style="display:flex;align-items:center;gap:10px"><i class="fa-solid fa-rocket"></i> GUARDAR VENTA</span><span class="arr"><i class="fa-solid fa-arrow-right"></i></span>';
    btn.disabled = false;
    cargar();
  }

  cargar();


  /* ═══════════════════════════════════════════
     FACTURACIÓN
  ═══════════════════════════════════════════ */
  const API_FACT = "https://script.google.com/macros/s/AKfycbxNxd1nWGmRAj_DPqrFkbcF5I5_wkxEAF1YYTEssj_jkocRUrG51nIA_2wvPjscHN6UGQ/exec";
  const STORAGE_KEY = 'dgp-docs-v2';
  let cart = [];
  let docs = [];

  /* Storage */
  async function saveDocs() {
    try { await window.storage.set(STORAGE_KEY, JSON.stringify(docs)); } catch(e) { localStorage.setItem(STORAGE_KEY, JSON.stringify(docs)); }
  }
  async function loadDocs() {
    try {
      const result = await window.storage.get(STORAGE_KEY);
      if (result && result.value) { docs = JSON.parse(result.value); return; }
    } catch(e) {}
    try { const d = localStorage.getItem(STORAGE_KEY); if (d) docs = JSON.parse(d); } catch(e) { docs = []; }
  }

  /* Type change */
  function onTypeChange() {
    const type = document.getElementById('doc-type').value;
    document.getElementById('field-nota').style.display = type === 'factura' ? 'block' : 'none';
    document.getElementById('btn-submit').innerText = type === 'factura' ? '🧾 Generar Factura' : '✅ Generar Recibo';
  }

  /* Cart */
  function addItem() {
    const s = document.getElementById('srv-sel').value;
    const p = parseFloat(document.getElementById('srv-pre').value);
    const c = parseInt(document.getElementById('srv-can').value) || 1;
    if (!s || isNaN(p) || p <= 0) return;
    cart.push({ s, p, c, t: parseFloat((p * c).toFixed(2)) });
    renderCart();
    document.getElementById('srv-sel').selectedIndex = 0;
    document.getElementById('srv-pre').value = '';
    document.getElementById('srv-can').value = '1';
  }

  function removeItem(idx) { cart.splice(idx, 1); renderCart(); }

  function renderCart() {
    const empty = cart.length === 0;
    document.getElementById('cart-empty').style.display  = empty ? 'block' : 'none';
    document.getElementById('cart-table').style.display  = empty ? 'none' : 'table';
    document.getElementById('cart-total').style.display  = empty ? 'none' : 'flex';
    document.getElementById('cart-list').innerHTML = cart.map((item, i) => `
      <tr>
        <td><div style="font-weight:500">${item.s}</div><div style="font-size:10px;color:var(--text-soft)">x${item.c} · $${item.p.toFixed(2)} c/u</div></td>
        <td style="text-align:right;font-weight:600">$${item.t.toFixed(2)}</td>
        <td><button class="remove-btn" onclick="removeItem(${i})">×</button></td>
      </tr>`).join('');
    document.getElementById('cart-total-val').innerText = '$' + cart.reduce((a,b) => a+b.t, 0).toFixed(2);
  }

  function fmtDate(d) {
    const dt = d ? new Date(d) : new Date();
    return `${String(dt.getDate()).padStart(2,'0')}/${String(dt.getMonth()+1).padStart(2,'0')}/${dt.getFullYear()}`;
  }

  async function saveDoc() {
    const cli  = document.getElementById('cli-nom').value.trim();
    const ref  = document.getElementById('pago-ref').value.trim() || '—';
    const nota = document.getElementById('doc-nota').value.trim();
    const type = document.getElementById('doc-type').value;
    if (!cli || cart.length === 0) return alert('⚠️ Completa el nombre del cliente y añade al menos un servicio.');

    const btn = document.getElementById('btn-submit');
    btn.disabled = true; btn.innerText = 'Procesando...';

    const total  = cart.reduce((a,b) => a+b.t, 0);
    const prefix = type === 'factura' ? 'FAC' : 'REC';
    const id     = prefix + '-' + Math.floor(Math.random()*9000+1000);
    const fecha  = fmtDate();
    const doc    = { id, type, cli, ref, nota, fecha, total, items: [...cart], pagado: type === 'recibo' };

    docs.unshift(doc);
    await saveDocs();

    try {
      await fetch(API_FACT, {
        method:'POST', mode:'no-cors', cache:'no-cache',
        headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ nombre:cli, items:cart, subtotal:total, descuentoPct:0, totalFinal:total, tipo:type })
      });
    } catch(e) {}

    cart = []; renderCart();
    document.getElementById('cli-nom').value  = '';
    document.getElementById('pago-ref').value = '';
    document.getElementById('doc-nota').value = '';
    btn.disabled = false;
    btn.innerText = type === 'factura' ? '🧾 Generar Factura' : '✅ Generar Recibo';

    // Update historial badge
    const tabHist = document.querySelectorAll('.subtab-btn')[1];
    tabHist.innerText = `📋 Historial (${docs.length})`;

    openSheet(doc);
  }

  function openSheet(doc) {
    const isFactura = doc.type === 'factura' && !doc.pagado;
    document.getElementById('sheet-top').innerHTML = `
      <div class="${isFactura ? 'sheet-top-factura' : 'sheet-top-recibo'}">
        <div class="sheet-doc-type">DGP Group</div>
        <div class="sheet-title">${isFactura ? 'FACTURA' : 'RECIBO DE PAGO'}</div>
        <div class="sheet-status-badge ${isFactura ? 'pendiente' : 'pagado'}">
          ${isFactura ? 'PENDIENTE DE PAGO' : 'PAGO CONFIRMADO'}
        </div>
      </div>`;
    document.getElementById('sheet-zigzag').innerHTML =
      `<div class="${isFactura ? 'sheet-zigzag-dark' : 'sheet-zigzag-blue'}"></div>`;

    document.getElementById('s-id').innerText    = doc.id;
    document.getElementById('s-fecha').innerText = doc.fecha;
    document.getElementById('s-cli').innerText   = doc.cli;
    document.getElementById('s-ref').innerText   = doc.ref && doc.ref !== '—' ? '📌 Ref: ' + doc.ref : '';

    const clientBlock = document.getElementById('s-client-block');
    const clientLabel = document.getElementById('s-client-label');
    clientBlock.className = `sheet-client-block ${isFactura ? 'factura-style' : 'recibo-style'}`;
    clientLabel.className = `sheet-client-label ${isFactura ? 'factura-style' : 'recibo-style'}`;

    const notaBlock = document.getElementById('s-nota-block');
    if (isFactura && doc.nota) {
      document.getElementById('s-nota').innerText = doc.nota;
      notaBlock.style.display = 'block';
    } else { notaBlock.style.display = 'none'; }

    document.getElementById('s-items').innerHTML = doc.items.map(i => `
      <tr>
        <td><div class="item-name">${i.s}</div><div class="item-qty">Cantidad: ${i.c}</div></td>
        <td>$${i.t.toFixed(2)}</td>
      </tr>`).join('');

    const totalBlock = document.getElementById('s-total-block');
    totalBlock.className = `sheet-total-block ${isFactura ? 'factura-style' : 'recibo-style'}`;
    document.getElementById('s-total-label').innerText = isFactura ? 'Total a Pagar' : 'Total Pagado';
    document.getElementById('s-total').innerText = doc.total.toFixed(2);

    document.getElementById('s-footer-text').innerHTML = isFactura
      ? 'Una vez realizado el pago, recibirás tu recibo de confirmación.<br><strong>DGP Group — Servicios Digitales Profesionales</strong>'
      : '¡Gracias por su preferencia!<br><strong>DGP Group — Servicios Digitales Profesionales</strong>';

    const actions = document.getElementById('sheet-actions');
    if (isFactura) {
      actions.className = 'sheet-actions three';
      actions.innerHTML = `
        <button class="btn-sheet print" onclick="window.print()">🖨️ Imprimir</button>
        <button class="btn-sheet marcar" onclick="marcarPagado('${doc.id}')">✅ Marcar pagado</button>
        <button class="btn-sheet close" onclick="closeModal()">Cerrar</button>`;
    } else {
      actions.className = 'sheet-actions';
      actions.innerHTML = `
        <button class="btn-sheet print" onclick="window.print()">🖨️ Imprimir</button>
        <button class="btn-sheet close" onclick="closeModal()">Cerrar</button>`;
    }

    document.getElementById('modalDoc').classList.add('show');
  }

  async function marcarPagado(id) {
    const doc = docs.find(d => d.id === id);
    if (!doc) return;
    doc.pagado = true; doc.type = 'recibo'; doc.fechaPago = fmtDate();
    const numPart = doc.id.split('-')[1];
    doc.id = 'REC-' + numPart;
    doc.ref = doc.ref && doc.ref !== '—' ? doc.ref : 'Pago confirmado';
    await saveDocs();
    openSheet(doc);
  }

  function renderHistorial() {
    const container = document.getElementById('hist-list');
    if (docs.length === 0) {
      container.innerHTML = '<div style="text-align:center;color:var(--text-soft);font-size:12px;padding:24px 0;">Sin documentos registrados aún</div>';
      return;
    }
    container.innerHTML = docs.map(doc => {
      const isFactura = doc.type === 'factura' && !doc.pagado;
      return `
      <div class="doc-item">
        <div class="doc-badge ${isFactura ? 'factura' : 'recibo'}">${isFactura ? 'Factura' : 'Recibo'}</div>
        <div class="doc-info">
          <div class="doc-id">${doc.id}</div>
          <div class="doc-name">${doc.cli}</div>
          <div class="doc-date">${doc.fecha}</div>
        </div>
        <div class="doc-amount">$${doc.total.toFixed(2)}</div>
        <div class="doc-actions">
          ${isFactura ? `<button class="btn-sm paid" onclick='marcarPagadoFromList("${doc.id}")'>✅ Pagado</button>` : ''}
          <button class="btn-sm outline" onclick='openSheetById("${doc.id}")'>Ver</button>
        </div>
      </div>`;
    }).join('');
  }

  function openSheetById(id)        { const d = docs.find(x => x.id === id); if (d) openSheet(d); }
  function marcarPagadoFromList(id) { marcarPagado(id); }

  function closeModal() {
    document.getElementById('modalDoc').classList.remove('show');
    renderHistorial();
    const tabHist = document.querySelectorAll('.subtab-btn')[1];
    tabHist.innerText = `📋 Historial (${docs.length})`;
  }

  document.getElementById('modalDoc').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });

  async function fetchSheetHistory() {
    try {
      const res  = await fetch(API_FACT + '?v=' + Math.random());
      const data = await res.json();
      if (!Array.isArray(data)) return;
      const existingIds = new Set(docs.map(d => d.id));
      let added = 0;
      data.forEach(f => {
        const id = f.id || ('REC-' + Math.floor(Math.random()*9000+1000));
        if (existingIds.has(id)) return;
        const srv = f.servicios || f.items || '—';
        const tot = parseFloat(f.total || f.totalFinal || 0);
        docs.push({ id, type:'recibo', pagado:true, cli:f.cliente||f.nombre||'—', ref:f.ref||'Venta registrada', nota:'', fecha:fmtDate(f.fecha), total:tot, items:[{s:srv,p:tot,c:1,t:tot}] });
        added++;
      });
      if (added > 0) await saveDocs();
    } catch(e) {}
  }

  /* Init */
  (async () => {
    await loadDocs();
    await fetchSheetHistory();
    const tabHist = document.querySelectorAll('.subtab-btn')[1];
    tabHist.innerText = docs.length > 0 ? `📋 Historial (${docs.length})` : '📋 Historial';
  })();
</script>

</body>
</html>
