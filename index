<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DGP Group | Sistema Completo</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { max-width: 100%; overflow-x: hidden; }

    :root {
      --white:      #ffffff;
      --off:        #f7f7f5;
      --black:      #0a0a0a;
      --blue:       #1438cc;
      --blue-light: #2a52e0;
      --blue-xlight:#eff6ff;
      --muted:      #2a3f7e;
      --border:     #e8e8e4;
      --text-soft:  #64748b;
      --green:      #22c55e;
      --green-dark: #059669;
      --green-light:#ecfdf5;
      --amber:      #d97706;
      --amber-light:#fffbeb;
      --text-mid:   #334155;
      --bg-alt:     #f0f5ff;
    }

    body {
      background: var(--white);
      color: var(--black);
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
    }

    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: radial-gradient(circle, #c8c8c8 1px, transparent 1px);
      background-size: 36px 36px;
      opacity: 0.28;
      pointer-events: none;
      z-index: 0;
    }
    body::after {
      content: '';
      position: fixed;
      width: 800px; height: 800px;
      background: radial-gradient(circle, rgba(20,56,204,0.05) 0%, transparent 65%);
      top: 0; left: 50%; transform: translateX(-50%);
      pointer-events: none; z-index: 0;
    }

    /* ─── HEADER ─── */
    .header {
      position: sticky; top: 0; z-index: 200;
      display: flex; justify-content: space-between; align-items: center;
      padding: 15px 32px;
      border-bottom: 1px solid var(--border);
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(16px);
    }
    .logo-text {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 20px; letter-spacing: 3px; color: var(--black);
    }
    .logo-text span { color: var(--blue); }
    .logo-sub { font-size: 9px; color: var(--text-soft); letter-spacing: 3px; text-transform: uppercase; font-weight: 300; margin-top: 1px; }

    .header-right { display: flex; gap: 12px; align-items: center; }
    .badge-bono {
      border: 1px solid var(--border);
      color: var(--black); padding: 5px 14px;
      font-size: 11px; font-weight: 500; letter-spacing: 1px;
      text-transform: uppercase;
      background: var(--off);
    }
    .live-dot {
      display: flex; align-items: center; gap: 6px;
      font-size: 11px; color: var(--green); font-weight: 500; letter-spacing: 1px;
      text-transform: uppercase;
    }
    .live-dot::before {
      content: ''; width: 7px; height: 7px; border-radius: 50%;
      background: var(--green); display: block;
      animation: blink 1.5s ease-in-out infinite;
    }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.2} }

    /* ─── NAV TABS ─── */
    .nav-tabs {
      position: relative; z-index: 100;
      display: flex; border-bottom: 1px solid var(--border);
      background: rgba(255,255,255,0.92);
      backdrop-filter: blur(12px);
      padding: 0 32px;
    }
    .nav-tab {
      padding: 14px 24px;
      font-family: 'DM Sans', sans-serif;
      font-size: 11px; font-weight: 500; letter-spacing: 2px; text-transform: uppercase;
      color: var(--text-soft); background: none; border: none; cursor: pointer;
      border-bottom: 2px solid transparent;
      transition: color 0.2s, border-color 0.2s;
      display: flex; align-items: center; gap: 8px;
    }
    .nav-tab:hover { color: var(--blue); }
    .nav-tab.active { color: var(--blue); border-bottom-color: var(--blue); }

    /* ─── TICKER ─── */
    .ticker {
      position: relative; z-index: 9;
      border-bottom: 1px solid var(--border);
      padding: 9px 32px;
      font-size: 11px; font-weight: 400; letter-spacing: 1.5px;
      color: var(--blue); text-transform: uppercase;
      display: none; overflow: hidden;
      background: rgba(20,56,204,0.03);
    }
    .ticker-inner { display: inline-block; animation: ticker-scroll 18s linear infinite; white-space: nowrap; }
    @keyframes ticker-scroll { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }

    /* ─── PAGE WRAPPERS ─── */
    .page { display: none; position: relative; z-index: 5; }
    .page.active { display: block; }

    /* ════════════════════════════
       PAGE 1 — PANEL DE VENTAS
    ════════════════════════════ */
    .ventas-main {
      max-width: 1050px; margin: 0 auto;
      padding: 32px 24px;
    }

    /* META HERO */
    .meta-hero {
      background: var(--black);
      padding: 32px 36px;
      margin-bottom: 12px;
      position: relative; overflow: hidden;
    }
    .meta-hero::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg, var(--blue), var(--blue-light), var(--blue));
      background-size: 200% 100%;
      animation: slideLine 3s ease-in-out infinite;
    }
    @keyframes slideLine { 0%{background-position:0% center}50%{background-position:100% center}100%{background-position:0% center} }

    .meta-top {
      display: flex; justify-content: space-between; align-items: flex-start;
      margin-bottom: 28px; flex-wrap: wrap; gap: 16px;
    }
    .semana-label { font-size: 10px; letter-spacing: 2.5px; text-transform: uppercase; color: rgba(255,255,255,0.45); margin-bottom: 6px; font-weight: 300; }
    .semana-title { font-family: 'Bebas Neue', sans-serif; font-size: 28px; color: var(--white); letter-spacing: 1px; }

    .meta-amounts { display: flex; gap: 40px; align-items: flex-end; }
    .amount-block { text-align: right; }
    .amount-label { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.45); font-weight: 300; }
    .amount-value { font-family: 'Bebas Neue', sans-serif; font-size: 48px; color: var(--white); line-height: 1; }
    .amount-value em { font-style: normal; color: var(--blue); font-size: 26px; }
    .amount-faltante { font-size: 11px; font-weight: 400; color: rgba(255,255,255,0.6); letter-spacing: 0.5px; margin-top: 4px; display: block; }

    .progress-track { height: 2px; background: rgba(255,255,255,0.12); position: relative; margin-bottom: 10px; }
    .progress-fill {
      height: 100%; width: 0%;
      background: var(--blue);
      transition: width 1.8s cubic-bezier(0.34, 1.56, 0.64, 1);
      position: relative;
    }
    .progress-fill::after {
      content: ''; position: absolute; right: -5px; top: 50%; transform: translateY(-50%);
      width: 10px; height: 10px; border-radius: 50%;
      background: var(--blue); box-shadow: 0 0 10px rgba(20,56,204,0.6);
    }
    .progress-labels { display: flex; justify-content: space-between; font-size: 10px; color: rgba(255,255,255,0.3); font-weight: 300; letter-spacing: 0.5px; }

    /* RANKING */
    .ranking-grid {
      display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 1px; background: var(--border);
      border: 1px solid var(--border);
      margin-bottom: 12px;
    }
    .rank-card {
      background: var(--white); padding: 24px 20px;
      text-align: center; position: relative; overflow: hidden;
      transition: background 0.25s; cursor: default;
    }
    .rank-card:hover { background: rgba(20,56,204,0.03); }
    .rank-card.leader { background: rgba(20,56,204,0.05); }
    .rank-card.leader::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: var(--blue); }
    .rank-medal { position: absolute; top: 8px; right: 10px; font-size: 18px; }
    .rank-streak { position: absolute; top: 8px; left: 10px; font-size: 15px; }
    .rank-avatar {
      width: 40px; height: 40px; border-radius: 0;
      background: var(--black);
      margin: 0 auto 12px;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Bebas Neue', sans-serif; font-size: 18px; color: var(--white);
    }
    .rank-card.leader .rank-avatar { background: var(--blue); }
    .rank-name { font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--text-soft); font-weight: 400; margin-bottom: 8px; }
    .rank-total { font-family: 'Bebas Neue', sans-serif; font-size: 28px; color: var(--black); line-height: 1; }
    .rank-card.leader .rank-total { color: var(--blue); }

    /* BOTTOM ROW VENTAS */
    .bottom-row { display: grid; grid-template-columns: 1fr 1.5fr; gap: 12px; }

    .panel-v {
      border: 1px solid var(--border);
      background: var(--white);
      padding: 28px 28px 24px;
    }
    .panel-title-v {
      font-size: 10px; letter-spacing: 2.5px; text-transform: uppercase;
      color: var(--blue); font-weight: 500; margin-bottom: 20px;
      display: flex; align-items: center; gap: 8px;
    }
    .panel-title-v::before { content:''; display:block; width:16px; height:1px; background:var(--blue); }

    /* Form fields */
    .field-group { margin-bottom: 10px; }
    .field-label { font-size: 9px; letter-spacing: 2.5px; text-transform: uppercase; color: var(--text-soft); margin-bottom: 6px; display: block; font-weight: 400; }
    .field-group select, .field-group input {
      width: 100%; padding: 11px 14px;
      background: var(--off); border: 1px solid var(--border); border-radius: 0;
      color: var(--black); font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 400;
      outline: none; transition: border-color 0.2s, background 0.2s;
      -webkit-appearance: none; appearance: none;
    }
    .field-group select:focus, .field-group input:focus { border-color: var(--blue); background: var(--white); }
    .field-group input::placeholder { color: var(--text-soft); font-weight: 300; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }

    .btn-reg {
      width: 100%; padding: 15px 20px;
      background: var(--blue); color: var(--white);
      border: none; border-radius: 100px;
      font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 500; letter-spacing: 1.5px;
      text-transform: uppercase; cursor: pointer; margin-top: 14px;
      display: flex; align-items: center; justify-content: space-between;
      transition: background 0.25s, transform 0.2s;
    }
    .btn-reg:hover { background: var(--blue-light); transform: translateY(-2px); }
    .btn-reg:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
    .btn-reg .arr { width: 24px; height: 24px; background: rgba(255,255,255,0.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 9px; transition: transform 0.25s; }
    .btn-reg:hover .arr { transform: rotate(45deg); }

    /* Filtros */
    .filtros { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 16px; }
    .btn-filter {
      padding: 5px 14px; background: var(--off); border: 1px solid var(--border);
      color: var(--text-soft); font-family: 'DM Sans', sans-serif;
      font-size: 10px; font-weight: 500; letter-spacing: 1.5px; text-transform: uppercase;
      cursor: pointer; transition: background 0.2s, color 0.2s, border-color 0.2s;
    }
    .btn-filter:hover { border-color: var(--blue); color: var(--blue); }
    .btn-filter.active { background: var(--blue); border-color: var(--blue); color: var(--white); }

    /* Venta rows */
    .venta-row {
      display: flex; align-items: center; gap: 10px;
      padding: 11px 0; border-bottom: 1px solid rgba(0,0,0,0.04);
      animation: fadeIn 0.4s ease both;
    }
    .venta-row:last-child { border-bottom: none; }
    @keyframes fadeIn { from{opacity:0;transform:translateY(4px)} to{opacity:1;transform:translateY(0)} }
    .venta-avatar { width: 30px; height: 30px; flex-shrink: 0; background: var(--black); display: flex; align-items: center; justify-content: center; font-family: 'Bebas Neue', sans-serif; font-size: 14px; color: var(--white); }
    .venta-info { flex: 1; min-width: 0; }
    .venta-name { font-size: 12px; font-weight: 500; color: var(--black); }
    .venta-client { font-size: 11px; color: var(--text-soft); font-weight: 300; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .venta-service { font-size: 10px; letter-spacing: 1px; text-transform: uppercase; color: var(--blue); border: 1px solid var(--border); padding: 2px 8px; white-space: nowrap; }
    .venta-date { font-size: 10px; color: var(--text-soft); white-space: nowrap; font-weight: 300; }
    .venta-amount { font-family: 'Bebas Neue', sans-serif; font-size: 18px; color: var(--green); white-space: nowrap; }
    .empty-state { text-align: center; padding: 40px 0; color: var(--text-soft); font-size: 13px; font-weight: 300; }
    .empty-state div { font-size: 28px; margin-bottom: 8px; }

    /* ════════════════════════════
       PAGE 2 — FACTURACIÓN
    ════════════════════════════ */
    .fact-main {
      max-width: 1000px; margin: 0 auto;
      padding: 28px 24px;
    }

    /* Subtabs */
    .subtabs { display: flex; gap: 0; margin-bottom: 20px; }
    .subtab-btn {
      flex: 1; padding: 13px 10px;
      background: white; border: 1.5px solid var(--border);
      font-family: 'IBM Plex Sans', sans-serif; font-size: 11px; font-weight: 600;
      letter-spacing: 2px; text-transform: uppercase; color: var(--text-soft); cursor: pointer;
      transition: all 0.2s;
    }
    .subtab-btn:first-child { border-radius: 10px 0 0 10px; border-right-width: 0.75px; }
    .subtab-btn:last-child  { border-radius: 0 10px 10px 0; border-left-width: 0.75px; }
    .subtab-btn.active { background: var(--blue); color: white; border-color: var(--blue); box-shadow: 0 4px 16px rgba(20,56,204,0.3); }

    /* Panels */
    .fact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
    .panel-f { background: white; border: 1px solid var(--border); border-radius: 18px; padding: 24px; box-shadow: 0 2px 12px rgba(0,0,0,0.04); }
    .panel-f-full { grid-column: 1 / -1; }
    .panel-title-f { font-family: 'IBM Plex Sans', sans-serif; font-size: 11px; font-weight: 600; letter-spacing: 3px; text-transform: uppercase; color: var(--blue); margin-bottom: 18px; display: flex; align-items: center; gap: 8px; }
    .panel-title-f::before { content:''; width:3px; height:14px; background:var(--blue); border-radius:2px; display:block; }

    /* Fields facturacion */
    .ff { margin-bottom: 13px; }
    .ff label { display: block; font-size: 9px; font-weight: 600; letter-spacing: 3px; text-transform: uppercase; color: var(--text-soft); margin-bottom: 5px; }
    .ff input, .ff select, .ff textarea {
      width: 100%; padding: 11px 14px;
      background: #f8fafc; border: 1.5px solid var(--border); border-radius: 10px;
      color: var(--black); font-family: 'IBM Plex Sans', sans-serif; font-size: 13px;
      outline: none; -webkit-appearance: none;
      transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
    }
    .ff input:focus, .ff select:focus, .ff textarea:focus { border-color: var(--blue); background: white; box-shadow: 0 0 0 3px rgba(20,56,204,0.08); }
    .ff input::placeholder, .ff textarea::placeholder { color: #cbd5e1; }
    .ff textarea { resize: vertical; min-height: 72px; font-size: 12px; }
    .ff-row { display: grid; grid-template-columns: 1fr 80px; gap: 10px; }

    .btn-add-f { width:100%; padding:12px; background:var(--black); color:white; border:none; border-radius:10px; font-family:'IBM Plex Sans',sans-serif; font-size:11px; font-weight:600; letter-spacing:2px; text-transform:uppercase; cursor:pointer; transition:all 0.2s; margin-top:12px; }
    .btn-add-f:hover { background:#1e293b; transform:translateY(-1px); }
    .btn-primary-f { width:100%; padding:15px; background:linear-gradient(135deg,var(--blue),#0080ff); color:white; border:none; border-radius:12px; font-family:'IBM Plex Sans',sans-serif; font-size:12px; font-weight:600; letter-spacing:3px; text-transform:uppercase; cursor:pointer; margin-top:10px; transition:all 0.3s; box-shadow:0 6px 20px rgba(20,56,204,0.3); position:relative; overflow:hidden; }
    .btn-primary-f:hover { transform:translateY(-2px); box-shadow:0 12px 28px rgba(20,56,204,0.4); }
    .btn-primary-f:disabled { opacity:0.6; cursor:not-allowed; transform:none; }

    /* Cart */
    .cart-table { width:100%; border-collapse:collapse; }
    .cart-table th { font-size:9px; font-weight:600; letter-spacing:2px; text-transform:uppercase; color:var(--text-soft); padding:6px; border-bottom:1px solid var(--border); text-align:left; }
    .cart-table td { padding:9px 6px; font-size:12px; border-bottom:1px solid #f8fafc; vertical-align:middle; }
    .cart-table tr:last-child td { border-bottom:none; }
    .remove-btn { background:none; border:none; color:#ef4444; cursor:pointer; font-size:16px; line-height:1; padding:0 4px; }
    .cart-total { display:flex; justify-content:space-between; align-items:center; padding:14px 6px 0; border-top:2px solid var(--border); margin-top:8px; }
    .cart-total-label { font-size:10px; font-weight:600; letter-spacing:2px; text-transform:uppercase; color:var(--text-soft); }
    .cart-total-value { font-family:'Bebas Neue',sans-serif; font-size:24px; font-weight:800; color:var(--blue); }
    .empty-cart { text-align:center; padding:24px 0; color:var(--text-soft); font-size:12px; }

    /* Historial docs */
    .doc-item { display:flex; align-items:center; gap:12px; padding:13px 16px; background:#f8fafc; border:1px solid var(--border); border-radius:14px; margin-bottom:8px; transition:all 0.2s; cursor:default; }
    .doc-item:hover { border-color:rgba(20,56,204,0.2); background:var(--blue-xlight); }
    .doc-badge { padding:4px 10px; border-radius:6px; font-size:9px; font-weight:700; letter-spacing:2px; text-transform:uppercase; white-space:nowrap; flex-shrink:0; }
    .doc-badge.factura { background:var(--amber-light); color:var(--amber); border:1px solid rgba(217,119,6,0.2); }
    .doc-badge.recibo  { background:var(--green-light); color:var(--green-dark); border:1px solid rgba(5,150,105,0.2); }
    .doc-info { flex:1; min-width:0; }
    .doc-id   { font-size:9px; font-weight:600; letter-spacing:2px; color:var(--blue); }
    .doc-name { font-size:13px; font-weight:600; color:var(--black); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .doc-date { font-size:10px; color:var(--text-soft); }
    .doc-amount { font-family:'Bebas Neue',sans-serif; font-size:16px; font-weight:800; color:var(--black); white-space:nowrap; flex-shrink:0; }
    .doc-actions { display:flex; gap:6px; flex-shrink:0; }
    .btn-sm { padding:6px 12px; border-radius:8px; font-family:'IBM Plex Sans',sans-serif; font-size:10px; font-weight:600; letter-spacing:1px; cursor:pointer; transition:all 0.2s; border:1.5px solid; white-space:nowrap; }
    .btn-sm.outline { background:white; border-color:var(--border); color:var(--text-mid); }
    .btn-sm.outline:hover { border-color:var(--blue); color:var(--blue); background:var(--blue-xlight); }
    .btn-sm.paid { background:var(--green-light); border-color:rgba(5,150,105,0.3); color:var(--green-dark); }
    .btn-sm.paid:hover { background:#d1fae5; }

    /* ─── MODAL VENTA ─── */
    .modal-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(10,10,10,0.65); backdrop-filter: blur(8px);
      z-index: 9999; justify-content: center; align-items: center;
    }
    .modal-overlay.show { display: flex; }
    .modal-box {
      background: var(--white); border: 1px solid var(--border);
      padding: 48px 40px; text-align: center; max-width: 380px; width: 90%;
      animation: modalIn 0.5s cubic-bezier(0.34,1.56,0.64,1);
      position: relative;
    }
    .modal-box::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--blue), var(--blue-light)); }
    @keyframes modalIn { from{opacity:0;transform:scale(0.8) translateY(20px)} to{opacity:1;transform:scale(1)} }
    .modal-icon { font-size: 56px; display: block; margin-bottom: 16px; }
    .modal-title { font-family: 'Bebas Neue', sans-serif; font-size: 36px; color: var(--black); margin-bottom: 8px; letter-spacing: 0.5px; }
    .modal-sub { font-size: 13px; color: var(--text-soft); font-weight: 300; margin-bottom: 28px; line-height: 1.7; border-left: 2px solid var(--border); padding-left: 14px; text-align: left; }
    .btn-wa { display: flex; width: 100%; align-items: center; justify-content: space-between; background: var(--black); color: var(--white); text-decoration: none; padding: 15px 20px; border-radius: 100px; font-size: 12px; font-weight: 500; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 10px; transition: background 0.25s, transform 0.2s; }
    .btn-wa:hover { background: var(--green); transform: translateY(-2px); }
    .btn-wa .arr { width: 24px; height: 24px; background: rgba(255,255,255,0.12); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 9px; transition: transform 0.25s; }
    .btn-wa:hover .arr { transform: rotate(45deg); }
    .btn-close { display: block; width: 100%; background: transparent; border: 1px solid var(--border); color: var(--text-soft); padding: 12px; font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 400; letter-spacing: 1px; text-transform: uppercase; cursor: pointer; transition: background 0.2s, color 0.2s; }
    .btn-close:hover { background: var(--off); color: var(--black); }

    /* ─── MODAL DOCUMENTO ─── */
    .doc-sheet {
      background: white; border-radius: 24px;
      max-width: 430px; width: 100%;
      overflow: hidden; box-shadow: 0 40px 80px rgba(0,0,0,0.2);
      animation: modalIn 0.4s cubic-bezier(0.34,1.56,0.64,1);
      max-height: 92vh; overflow-y: auto;
    }
